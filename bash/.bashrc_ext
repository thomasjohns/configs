# bashrc extensions
# Source this file from your main ~/.bashrc:
#   if [ -f ~/.bashrc_ext ]; then . ~/.bashrc_ext; fi

# --- Aliases ---
alias l='eza'
alias la='eza -a'
alias ll='eza -lah'
alias ls='eza --color=auto'
alias j='just'
alias k='kubectl'
alias gc='gcloud'

# --- Environment Variables ---
export EDITOR=nvim
export VISUAL=nvim

# --- PATH additions ---

# --- Prompt ---

# --- Functions ---

# nvim on changed files from git status
nvim-changed() {
    git status --porcelain | rg ' M ' | sd ' M ' '' | xargs nvim;
}

last-status() {
    echo $?;
}

cpignored() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: cpignored <src> <dest>"
        return 1
    fi

    local src="$(cd "$1" && pwd)"
    local dest="$(cd "$2" && pwd)"

    if ! git -C "$src" rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: '$1' is not inside a git repository"
        return 1
    fi

    local ignored_files
    ignored_files="$(git -C "$src" ls-files --others --ignored --exclude-standard)"
    if [ -z "$ignored_files" ]; then
        echo "No gitignored files found in '$1'"
        return 0
    fi

    echo "$ignored_files" | rsync -a --files-from=- "$src/" "$dest/"
    echo "Copied gitignored files from '$1' to '$2'"
}

cpunstaged() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: cpunstaged <src> <dest>"
        return 1
    fi

    local src="$(cd "$1" && pwd)"
    local dest="$(cd "$2" && pwd)"

    if ! git -C "$src" rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: '$1' is not inside a git repository"
        return 1
    fi

    local unstaged_files
    unstaged_files="$(git -C "$src" diff --name-only)"
    if [ -z "$unstaged_files" ]; then
        echo "No unstaged changes found in '$1'"
        return 0
    fi

    echo "$unstaged_files" | rsync -a --files-from=- "$src/" "$dest/"
    echo "Copied unstaged files from '$1' to '$2'"
}

cpuntracked() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: cpuntracked <src> <dest>"
        return 1
    fi

    local src="$(cd "$1" && pwd)"
    local dest="$(cd "$2" && pwd)"

    if ! git -C "$src" rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: '$1' is not inside a git repository"
        return 1
    fi

    local untracked_files
    untracked_files="$(git -C "$src" ls-files --others --exclude-standard)"
    if [ -z "$untracked_files" ]; then
        echo "No untracked files found in '$1'"
        return 0
    fi

    echo "$untracked_files" | rsync -a --files-from=- "$src/" "$dest/"
    echo "Copied untracked files from '$1' to '$2'"
}

cpchanges() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: cpchanges <src> <dest>"
        return 1
    fi

    local src="$(cd "$1" && pwd)"
    local dest="$(cd "$2" && pwd)"

    if ! git -C "$src" rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: '$1' is not inside a git repository"
        return 1
    fi

    local changed_files
    changed_files="$({ git -C "$src" diff --name-only; git -C "$src" ls-files --others --exclude-standard; } | sort -u)"
    if [ -z "$changed_files" ]; then
        echo "No changed or untracked files found in '$1'"
        return 0
    fi

    echo "$changed_files" | rsync -a --files-from=- "$src/" "$dest/"
    echo "Copied changed and untracked files from '$1' to '$2'"
}

bare() {
    if [ -z "$1" ]; then
        echo "Usage: bare <repo-name>"
        return 1
    fi
    git init --bare --initial-branch=main "$1.git"
    git -C "$1.git" worktree add --orphan main
}

git-branch-prune() {
    git branch --merged | grep -v '^\*' | grep -v 'main$' | grep -v 'master$' | xargs git branch -d
}

wt() {
    if [ -z "$1" ]; then
        echo "Usage: wt <worktree-name>"
        return 1
    fi

    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: not inside a git repository"
        return 1
    fi

    # Detect bare repo even when cd'd into one of its worktrees
    local git_common_dir
    git_common_dir="$(cd "$(git rev-parse --git-common-dir)" && pwd)"
    local is_bare
    is_bare="$(git config -f "$git_common_dir/config" --get core.bare 2>/dev/null)"

    if [ "$is_bare" = "true" ]; then
        _wt_bare "$1" "$git_common_dir"
    else
        _wt_normal "$1"
    fi
}

_wt_normal() {
    local name="$1"
    local repo_root
    repo_root="$(git rev-parse --show-toplevel)"

    local wt_path="$repo_root/$name"

    git worktree add "$wt_path" 2>/dev/null
    if [ $? -ne 0 ]; then
        echo "Error: failed to create worktree '$name'"
        return 1
    fi

    # Exclude the worktree directory from the outer repo's tracking
    local exclude_file="$repo_root/.git/info/exclude"
    if ! grep -qxF "$name" "$exclude_file" 2>/dev/null; then
        echo "$name" >> "$exclude_file"
    fi

    # Copy gitignored files to the new worktree
    local ignored_files
    ignored_files="$(git -C "$repo_root" ls-files --others --ignored --exclude-standard)"
    if [ -n "$ignored_files" ]; then
        echo "$ignored_files" | rsync -a --files-from=- "$repo_root/" "$wt_path/"
    fi

    echo "Worktree '$name' created at $wt_path"
}

_wt_bare() {
    local name="$1"
    local bare_root="$2"

    # Resolve the actual default branch name from HEAD
    local default_branch
    default_branch="$(git -C "$bare_root" symbolic-ref --short HEAD 2>/dev/null)"

    # If user typed "main" or "master", use the actual default branch name
    if [ "$name" = "main" ] || [ "$name" = "master" ]; then
        if [ -n "$default_branch" ] && [ "$name" != "$default_branch" ]; then
            echo "Note: default branch is '$default_branch', using that instead of '$name'"
            name="$default_branch"
        fi
    fi

    local wt_path="$bare_root/$name"

    git worktree add "$wt_path" 2>/dev/null
    if [ $? -ne 0 ]; then
        echo "Error: failed to create worktree '$name'"
        return 1
    fi

    # For non-default-branch worktrees, copy gitignored files from the primary worktree
    if [ "$name" != "$default_branch" ]; then
        local primary_wt=""
        if [ -n "$default_branch" ] && [ -d "$bare_root/$default_branch" ]; then
            primary_wt="$bare_root/$default_branch"
        fi

        if [ -n "$primary_wt" ]; then
            local ignored_files
            ignored_files="$(git -C "$primary_wt" ls-files --others --ignored --exclude-standard)"
            if [ -n "$ignored_files" ]; then
                echo "$ignored_files" | rsync -a --files-from=- "$primary_wt/" "$wt_path/"
            fi
        else
            echo "Warning: no '$default_branch' worktree found to copy gitignored files from"
        fi
    fi

    echo "Worktree '$name' created at $wt_path"
}

agents() {
    if [ -z "$1" ]; then
        echo "Usage: agents <number> [agent]"
        echo "  agent: claude (default), copilot"
        return 1
    fi

    local n="$1"
    local agent="${2:-claude}"
    local agent_cmd
    case "$agent" in
        claude)  agent_cmd="claude --dangerously-skip-permissions" ;;
        copilot) agent_cmd="copilot --yolo" ;;
        *)
            echo "Error: unknown agent '$agent' (supported: claude, copilot)"
            return 1
            ;;
    esac

    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: not inside a git repository"
        return 1
    fi

    # Determine worktree creation base directory
    local git_common_dir
    git_common_dir="$(cd "$(git rev-parse --git-common-dir)" && pwd)"
    local is_bare
    is_bare="$(git config -f "$git_common_dir/config" --get core.bare 2>/dev/null)"
    local wt_base
    if [ "$is_bare" = "true" ]; then
        wt_base="$git_common_dir"
    else
        wt_base="$(git rev-parse --show-toplevel)"
    fi

    # Resolve or create worktrees
    local wt_paths=()
    for i in $(seq 1 "$n"); do
        local wt_name="agent$i"
        local wt_path
        wt_path="$(git worktree list --porcelain | grep "^worktree " | sed 's/^worktree //' | grep "/${wt_name}$" | head -1)"
        if [ -z "$wt_path" ]; then
            (cd "$wt_base" && wt "$wt_name") || { echo "Failed to create worktree $wt_name"; return 1; }
            wt_path="$(git worktree list --porcelain | grep "^worktree " | sed 's/^worktree //' | grep "/${wt_name}$" | head -1)"
        fi
        if [ -z "$wt_path" ]; then
            echo "Error: could not find or create worktree '$wt_name'"
            return 1
        fi
        wt_paths+=("$wt_path")
    done

    # Set up tmux
    local first_pane
    if [ -n "$TMUX" ]; then
        first_pane="$(tmux display-message -p '#{pane_id}')"
        tmux send-keys -t "$first_pane" "cd '${wt_paths[0]}'" C-m
    else
        tmux new-session -d -s agents -c "${wt_paths[0]}"
        first_pane="$(tmux list-panes -t agents:0 -F '#{pane_id}' | head -1)"
    fi

    # Create columns via horizontal splits
    local col_panes=("$first_pane")
    local last_pane="$first_pane"
    for i in $(seq 2 "$n"); do
        local new_pane
        new_pane="$(tmux split-window -h -t "$last_pane" -c "${wt_paths[$((i-1))]}" -P -F '#{pane_id}')"
        col_panes+=("$new_pane")
        last_pane="$new_pane"
    done

    # Even out columns
    tmux select-layout -t "$first_pane" even-horizontal

    # Split each column into top/bottom rows
    for i in $(seq 0 $((n-1))); do
        tmux split-window -v -t "${col_panes[$i]}" -c "${wt_paths[$i]}"
    done

    # Start agent in each top pane
    for pane in "${col_panes[@]}"; do
        tmux send-keys -t "$pane" "$agent_cmd" C-m
    done

    # Attach if we created a new session
    if [ -z "$TMUX" ]; then
        tmux attach-session -t agents
    fi
}
